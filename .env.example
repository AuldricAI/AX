# AX — Environment Variables
# Copy this file to .env and fill in the values you need.

# ─── Clerk Authentication (Optional) ─────────────────────────────────
# Only required for "AX hosted mode" (using AX's built-in AI key).
# Leave blank to run in BYOK-only mode (no sign-in required).
VITE_CLERK_PUBLISHABLE_KEY=

# ─── AX Backend API (Optional) ───────────────────────────────────────
# The backend URL for AX hosted mode. Only relevant if using Clerk.
# Default: https://api.auldric.com
VITE_AX_API_BASE=https://api.auldric.com
