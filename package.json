{
    "name": "ax-browser",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "AX — Agentic Experience. Browser diagnostics for AI agents.",
    "scripts": {
        "dev": "vite build --watch --mode development",
        "build": "tsc && npx tsx scripts/build.ts",
        "preview": "web-ext run --source-dir dist",
        "build:zip": "npm run build && cd dist && zip -r ../ax-v.zip . -x \".*\" -x \"__MACOSX\" && cd .."
    },
    "dependencies": {
        "marked": "^17.0.4",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router": "^7.13.1"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.19",
        "@types/chrome": "^0.0.306",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.4.0",
        "autoprefixer": "^10.4.20",
        "postcss": "^8.5.0",
        "tailwindcss": "^3.4.17",
        "tsx": "^4.21.0",
        "typescript": "^5.9.0",
        "vite": "^6.0.0",
        "web-ext": "^8.4.0"
    },
    "license": "MIT"
}
